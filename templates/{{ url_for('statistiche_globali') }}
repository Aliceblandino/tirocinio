<!DOCTYPE html>
<html lang="it" data-bs-theme="dark">
<!-- serve solo per la personalizzazione dei grafici!!! -->
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Grafici Esami - UniUd</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.plot.ly/plotly-latest.min.js"></script>
    <style>
        body {
            background-color: #212529;
            color: #fff;
            padding: 30px;
        }
        #grafico {
            width: 100%;
            height: 500px;
        }
    </style>
</head>
<body>
    <h2>Distribuzione dei voti</h2>
    <p>Appello: {{ header.attivita }} - {{ header.sessione }}</p>

    <div id="grafico" data-graph='{{ graphJSON | tojson | safe }}'></div>

    <script>
        var graph = JSON.parse(document.getElementById('grafico').dataset.graph);
        Plotly.newPlot('grafico', graph);
    </script>

    <a href="{{ url_for('dashboard') }}" class="btn btn-light mt-4">Torna alla dashboard</a>
</body>
</html>